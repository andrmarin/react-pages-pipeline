# Copy this file to `.env.local` for local development.
#
# All VITE_* values are embedded into the client build and are PUBLIC.
# Use placeholder values only — never put a real secret here.
#
# VITE_APP_VERSION is NOT listed: it is read automatically from version.txt
# by vite.config.ts.

VITE_APP_ENV=development
VITE_AWS_KEY=AKIA_PLACEHOLDER_LOCAL
VITE_AWS_SECRET=placeholder-secret-local
VITE_S3_BUCKET=my-local-bucket
